{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "notetaker": {
          "name": "Nemotron Cascade 2 — Note Taker",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "note-drift": {
          "name": "Nemotron Cascade 2 — NoteDrift",
          "limit": {
            "context": 131072,
            "output": 8192
          }
        }
      }
    }
  },
  "plugin": [
    [
      ".opencode/plugins/obsidian_note_logger.ts",
      {
        "obsidian_note_logger": {
          "project": "obsidian-note-logger",
          "model": "notetaker",
          "base_url": "http://localhost:11434/v1",
          "api_key": "ollama",
          "ollama_model": "notetaker",
          "vault": "Diddys_Diaries",
          "note_skill": "obsidian-dev-notes",
          "min_tool_calls": 10,
          "min_messages": 8,
          "log_path": "wiki/log.md",
          "log_enabled": true,
          "toast_enabled": true,
          "os_notify": true
        }
      }
    ]
  ]
}
